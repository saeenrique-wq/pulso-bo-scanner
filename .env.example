# ── Servidor ──────────────────────────────────────────────
HOST=0.0.0.0
PORT=8082
SCAN_INTERVAL=60

# ── Activos (vacío = todos) ────────────────────────────────
# ASSETS=EURUSD,GBPUSD,XAUUSD

# ── Filtros ────────────────────────────────────────────────
MIN_PAYOUT_PCT=80

# ── Brokers habilitados (demo,quotex,pocketoption,iqoption) ─
ENABLED_BROKERS=demo

# ── Ollama AI ──────────────────────────────────────────────
OLLAMA_ENABLED=true
OLLAMA_MODEL=llama3.2:3b
OLLAMA_MIN_SCORE=0.38

# ── Telegram (grupo Pulso Capital MX-Trading Free) ─────────
TELEGRAM_TOKEN=tu_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# ── Quotex ────────────────────────────────────────────────
# QUOTEX_EMAIL=tu@email.com
# QUOTEX_PASSWORD=tu_password
# QUOTEX_DEMO=true

# ── Pocket Option ─────────────────────────────────────────
# POCKET_SSID=tu_ssid
# POCKET_DEMO=true

# ── IQ Option / Exnova ────────────────────────────────────
# IQOPTION_EMAIL=tu@email.com
# IQOPTION_PASSWORD=tu_password
# IQOPTION_DEMO=true
